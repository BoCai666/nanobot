{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "nanobot",
  "version": "0.1.0",
  "identifier": "ai.hkuds.nanobot",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:6100",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "nanobot",
        "width": 1024,
        "height": 768,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "HKUDS",
    "shortDescription": "Ultra-Lightweight Personal AI Assistant",
    "longDescription": "nanobot is an ultra-lightweight personal AI assistant framework. It delivers core agent functionality with 99% fewer lines of code than OpenClaw, supporting 12+ chat platforms with native OpenAI/Anthropic SDKs.",
    "category": "Utility",
    "license": "MIT",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/nanobot-sidecar"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": true
      }
    }
  }
}
